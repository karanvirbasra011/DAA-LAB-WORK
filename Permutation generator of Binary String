#include <iostream>
#include <chrono>
#include <vector>
#include <string>
#include <iomanip>
using namespace std;

void generateBinaryStrings(int string_length, int position, string &binary_str) {
    if (position == string_length) {
        // cout << binary_str << "\n";
        return;
    }
    binary_str[position] = '0';
    generateBinaryStrings(string_length, position + 1, binary_str);
    binary_str[position] = '1';
    generateBinaryStrings(string_length, position + 1, binary_str);
}

int main() {
    vector<vector<double>> time_records(10, vector<double>(10));
    vector<int> length_values = {5, 8, 10, 12, 14, 16, 18, 20, 21, 23};
    
    cout << "Binary String Permutation Generator\n";
    cout << "Student Roll: UEM243135\n\n";
    
    for (int test_index = 0; test_index < 10; test_index++) {
        int current_length = length_values[test_index];
        double sum_of_times = 0.0;
        
        for (int run_number = 0; run_number < 10; run_number++) {
            string binary_str(current_length, '0');
            
            auto start_time = chrono::high_resolution_clock::now();
            generateBinaryStrings(current_length, 0, binary_str);
            auto end_time = chrono::high_resolution_clock::now();
            
            chrono::duration<double, micro> time_difference = end_time - start_time;
            time_records[test_index][run_number] = time_difference.count();
            sum_of_times += time_difference.count();
        }
        
        double mean_time = sum_of_times / 10.0;
        cout << "String Length: " << current_length << " | Average Time: " << mean_time << " microseconds\n";
    }
    
    return 0;
}
