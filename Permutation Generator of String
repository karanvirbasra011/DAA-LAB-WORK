#include <iostream>
#include <chrono>
#include <vector>
#include <string>
#include <iomanip>
using namespace std;

void generateStringPermutations(int total_length, int current_pos, string &input_str) {
    if (current_pos == total_length) 
        return;
    
    for (int swap_pos = current_pos; swap_pos < total_length; swap_pos++) {
        swap(input_str[swap_pos], input_str[current_pos]);
        generateStringPermutations(total_length, current_pos + 1, input_str);
        swap(input_str[swap_pos], input_str[current_pos]);
    }
}

int main() {
    vector<vector<double>> execution_data(10, vector<double>(10));
    vector<string> test_strings = {"ab", "abc", "abcd", "abcde", "abcdef", "abcdefg", "abcdefgh", "abcdefghi", "abcdefghij", "abcdefghijk"};
    vector<int> string_lengths = {2, 3, 4, 5, 6, 7, 8, 9, 10, 10};
    
    cout << "String Permutation Generation Algorithm\n";
    cout << "Roll Number: UEM243135\n\n";
    
    for (int test_num = 0; test_num < 10; test_num++) {
        string input_str = test_strings[string_lengths[test_num] - 2];
        int str_length = input_str.length();
        double total_time_sum = 0.0;
        
        for (int trial = 0; trial < 10; trial++) {
            string working_copy = input_str;
            
            auto begin_time = chrono::high_resolution_clock::now();
            generateStringPermutations(str_length, 0, working_copy);
            auto finish_time = chrono::high_resolution_clock::now();
            
            chrono::duration<double, micro> elapsed_duration = finish_time - begin_time;
            execution_data[test_num][trial] = elapsed_duration.count();
            total_time_sum += elapsed_duration.count();
        }
        
        double average_time = total_time_sum / 10.0;
        cout << "String Length: " << str_length << " | Average Time: " << average_time << " microseconds\n";
    }
    
    return 0;
}
