#include <iostream>
using namespace std;

int sumRecursive(int n) {
    
    if (n <= 0) {
        return 0;
    }
    return n + sumRecursive(n - 1);
}

int sumIterative(int n) {
    int sum = 0;
    for (int i = 1; i <= n; i++) {
        sum += i;
    }
    return sum;
}

int sumFormula(int n) {
    return n * (n + 1) / 2;
}

int main() {
    int n;

    cout << "Enter a positive number: ";
    cin >> n;
    
    cout << "\nSum from 1 to " << n << ":\n";
    cout << "Recursive method: " << sumRecursive(n) << endl;
    cout << "Iterative method: " << sumIterative(n) << endl;
    cout << "Formula method: " << sumFormula(n) << endl;

    return 0;
}
