#include <iostream>
using namespace std;

int D[10][10];
int n;

void floydWarshall()
{
    for (int k = 0; k < n; k++)
        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++)
                if (D[i][k] + D[k][j] < D[i][j])
                    D[i][j] = D[i][k] + D[k][j];
}

void printMatrix()
{
    cout << "\nD (Shortest Distance Matrix):\n\n";
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            if (D[i][j] == 9999)
                cout << "INF\t";
            else
                cout << D[i][j] << "\t";
        }
        cout << endl;
    }
}

int main()
{
    cout << "Enter number of vertices: ";
    cin >> n;

    cout << "Enter adjacency matrix (9999 for no edge):\n";
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> D[i][j];

    for (int i = 0; i < n; i++)
        D[i][i] = 0;

    cout << "\nD0 (Input W matrix):\n";
    printMatrix();
    floydWarshall();
    cout << "\nFinal Answer:\n";
    printMatrix();

    return 0;
}
